# Database password (choose a strong one)
KC_DB_PASSWORD=change_me

# Initial admin user
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change_me

# If using Caddy + keycloak.lab, set:
# KC_HOSTNAME=keycloak.lab
# If accessing via Tailscale IP: use the URL/hostname you actually browse to.
KC_HOSTNAME=keycloak.lab
