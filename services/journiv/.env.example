# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me

# Set to the hostname you browse to (e.g. journiv.lab if using Caddy)
DOMAIN_NAME=journiv.lab

# Database password (required, no default)
POSTGRES_PASSWORD=change_me

# Optional overrides (defaults shown)
# POSTGRES_USER=journiv
# POSTGRES_DB=journiv_prod
# APP_VERSION=latest
# CELERY_WORKER_CONCURRENCY=1
# CELERY_WORKER_MAX_MEMORY_PER_CHILD_KB=300000
# CELERY_WORKER_MAX_TASKS_PER_CHILD=200
